# PostgreSQL
POSTGRES_USER=servicetracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=servicetracker

# Backend
DATABASE_URL=postgresql+asyncpg://servicetracker:changeme@db:5432/servicetracker
DATABASE_URL_SYNC=postgresql://servicetracker:changeme@db:5432/servicetracker
SECRET_KEY=change-this-to-a-random-string
UPLOADS_DIR=/app/uploads

# VAPID (generated on first run if empty)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@example.com
